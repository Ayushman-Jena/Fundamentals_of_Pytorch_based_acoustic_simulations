\section{Introduction}
Acoustic simulations model the propagation of pressure waves in a medium. These models range from linear approximations to highly nonlinear equations used in high-intensity focused ultrasound (HIFU).

\section{Fundamental Governing Equations}

\subsection{Continuity Equation}
\begin{equation}
\frac{\partial \rho}{\partial t} + \nabla \cdot (\rho \mathbf{v}) = 0
\end{equation}

\subsection{Momentum Equation (Euler's Equation)}
\begin{equation}
\rho \left( \frac{\partial \mathbf{v}}{\partial t} + (\mathbf{v} \cdot \nabla)\mathbf{v} \right) = -\nabla p
\end{equation}

\subsection{Equation of State}
\begin{equation}
p = p(\rho)
\end{equation}

For small perturbations:
\begin{equation}
p' = c^2 \rho'
\end{equation}

\section{Linear Acoustic Wave Equation}

Assuming small perturbations:

\begin{equation}
\nabla^2 p - \frac{1}{c^2} \frac{\partial^2 p}{\partial t^2} = 0
\end{equation}

\subsection{Velocity Potential Form}
\begin{equation}
\nabla^2 \phi - \frac{1}{c^2} \frac{\partial^2 \phi}{\partial t^2} = 0
\end{equation}

\section{Helmholtz Equation (Frequency Domain)}

Assuming harmonic solution $p = P e^{j\omega t}$:

\begin{equation}
\nabla^2 P + k^2 P = 0
\end{equation}

where:
\[
k = \frac{\omega}{c}
\]

\section{Attenuation and Absorption}

\begin{equation}
p(x) = p_0 e^{-\alpha x}
\end{equation}

\section{Nonlinear Acoustics}

\subsection{Westervelt Equation}

\begin{equation}
\nabla^2 p - \frac{1}{c^2} \frac{\partial^2 p}{\partial t^2}
= -\frac{\beta}{\rho c^4} \frac{\partial^2 (p^2)}{\partial t^2}
\end{equation}

where:
\[
\beta = 1 + \frac{B}{2A}
\]

\subsection{Khokhlov-Zabolotskaya-Kuznetsov (KZK) Equation}

\begin{equation}
\frac{\partial^2 p}{\partial z \partial t}
= \frac{c}{2} \nabla_\perp^2 p
+ \frac{\delta}{2c^3} \frac{\partial^3 p}{\partial t^3}
+ \frac{\beta}{2\rho c^3} \frac{\partial^2 (p^2)}{\partial t^2}
\end{equation}

\section{Burgers' Equation (1D Nonlinear Propagation)}

\begin{equation}
\frac{\partial p}{\partial x}
= \frac{\beta}{\rho c^3} p \frac{\partial p}{\partial \tau}
+ \frac{\delta}{2c^3} \frac{\partial^2 p}{\partial \tau^2}
\end{equation}

\section{Thermoviscous Effects}

\begin{equation}
\delta = \frac{2\alpha c^3}{\omega^2}
\end{equation}

\section{Acoustic Intensity}

\begin{equation}
I = \frac{p^2}{2 \rho c}
\end{equation}

\section{Radiation Force}

\begin{equation}
F = \frac{2 \alpha I}{c}
\end{equation}

\section{Boundary Conditions}

\subsection{Rigid Boundary}
\begin{equation}
\mathbf{v} \cdot \hat{n} = 0
\end{equation}

\subsection{Pressure Release Boundary}
\begin{equation}
p = 0
\end{equation}

\section{Piezoelectric Coupling (for Transducers)}

\subsection{Constitutive Equations}

\begin{equation}
S = s^E T + d^T E
\end{equation}

\begin{equation}
D = dT + \epsilon^T E
\end{equation}

\section{Summary}

\begin{itemize}
    \item Linear acoustics: Wave equation, Helmholtz equation
    \item Nonlinear acoustics: Westervelt, Burgers, KZK
    \item Transducer physics: Piezoelectric equations
    \item Energy quantities: Intensity, radiation force
\end{itemize}

